FROM rust:1.78-slim AS builder
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY apps/relay apps/relay
COPY packages/void-crypto packages/void-crypto
RUN cargo build --release -p void-relay

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates git && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/void-relay /usr/local/bin/void-relay
EXPOSE 8000
CMD ["void-relay"]
