# VoidPush local/staging configuration template.
# Copy values into your host or deployment secret manager. Do not commit real secrets.

# Web rewrites. Keep these private/internal in production when possible.
RELAY_API_URL=http://localhost:8000
SCORE_ENGINE_URL=http://localhost:8001

# Relay.
RELAY_ID=R-local
RELAY_REGION=local
PORT=8000
REGISTRY_URL=https://registry.voidpush.dev
MAX_PAYLOAD_BYTES=52428800
NODE_TYPE=community
# Generate locally, then store only in a secret manager:
# openssl rand -hex 32
RELAY_PRIVATE_KEY=replace-with-64-hex-characters

# Score engine.
ENV=development
DATABASE_URL=postgresql+asyncpg://ghost:ghost@localhost:5432/void_scores
REDIS_URL=redis://localhost:6379/0
AUDIT_LOG_PATH=./var/log/ghost-score/audit.jsonl
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MCP server / SDK defaults.
VOIDPUSH_API_URL=http://localhost:8000
